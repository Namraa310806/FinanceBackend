{
  "info": {
    "name": "Finance Dashboard API",
    "description": "Postman collection for testing the Finance Dashboard Django backend APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth & Users",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"StrongPass@123\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/register/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users",
                "register",
                ""
              ]
            },
            "description": "Register a new user. Role defaults to VIEWER."
          }
        },
        {
          "name": "Login (JWT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body && body.data) {",
                  "  if (body.data.access) pm.collectionVariables.set('access_token', body.data.access);",
                  "  if (body.data.refresh) pm.collectionVariables.set('refresh_token', body.data.refresh);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_doe\",\n  \"password\": \"StrongPass@123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/login/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users",
                "login",
                ""
              ]
            },
            "description": "Login user and automatically save access and refresh tokens into collection variables."
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/token/refresh/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users",
                "token",
                "refresh",
                ""
              ]
            },
            "description": "Refresh access token using stored refresh token."
          }
        },
        {
          "name": "Get Current User Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/me/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users",
                "me",
                ""
              ]
            },
            "description": "Returns authenticated user's profile."
          }
        },
        {
          "name": "Admin - List Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/manage/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users",
                "manage",
                ""
              ]
            },
            "description": "Admin-only endpoint for user listing."
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create Transaction",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": \"2500.00\",\n  \"type\": \"INCOME\",\n  \"category\": \"Salary\",\n  \"date\": \"2026-04-01\",\n  \"notes\": \"Monthly payroll\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/transactions/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "transactions",
                ""
              ]
            },
            "description": "Create a new transaction (ADMIN only)."
          }
        },
        {
          "name": "List Transactions (Filter + Search + Pagination)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/transactions/?start_date=2026-01-01&end_date=2026-12-31&type=EXPENSE&category=Food&search=dinner&page=1&page_size=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "transactions",
                ""
              ],
              "query": [
                {
                  "key": "start_date",
                  "value": "2026-01-01"
                },
                {
                  "key": "end_date",
                  "value": "2026-12-31"
                },
                {
                  "key": "type",
                  "value": "EXPENSE"
                },
                {
                  "key": "category",
                  "value": "Food"
                },
                {
                  "key": "search",
                  "value": "dinner"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "page_size",
                  "value": "10"
                }
              ]
            },
            "description": "Get paginated transactions with optional filters and search."
          }
        },
        {
          "name": "Retrieve Transaction",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/transactions/{{transaction_id}}/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "transactions",
                "{{transaction_id}}",
                ""
              ]
            },
            "description": "Get transaction by ID."
          }
        },
        {
          "name": "Update Transaction",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": \"2750.00\",\n  \"type\": \"INCOME\",\n  \"category\": \"Salary\",\n  \"date\": \"2026-04-02\",\n  \"notes\": \"Updated payroll\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/transactions/{{transaction_id}}/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "transactions",
                "{{transaction_id}}",
                ""
              ]
            },
            "description": "Update transaction by ID (ADMIN only)."
          }
        },
        {
          "name": "Delete Transaction (Soft Delete)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/transactions/{{transaction_id}}/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "transactions",
                "{{transaction_id}}",
                ""
              ]
            },
            "description": "Soft delete transaction by ID (ADMIN only)."
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Analytics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/dashboard/analytics/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "dashboard",
                "analytics",
                ""
              ]
            },
            "description": "Dashboard analytics (ANALYST or ADMIN)."
          }
        },
        {
          "name": "Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/dashboard/summary/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "dashboard",
                "summary",
                ""
              ]
            },
            "description": "Alias endpoint for dashboard analytics (ANALYST or ADMIN)."
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "transaction_id",
      "value": "1"
    }
  ]
}
